def iter_media(root: Path, recurse: bool, include_videos: bool) -> Iterable[Path]:
    exts = set(IMAGE_EXTENSIONS)
    if include_videos:
        exts |= VIDEO_EXTENSIONS
    if recurse:
        for path in root.rglob("*"):
            if path.is_file() and path.suffix.lower() in exts:
                yield path
    else:
        for path in root.iterdir():
            if path.is_file() and path.suffix.lower() in exts:
                yield path


def is_video(path: Path) -> bool:
    return path.suffix.lower() in VIDEO_EXTENSIONS


def is_image(path: Path) -> bool:
    return path.suffix.lower() in IMAGE_EXTENSIONS


def read_labels(labels_file: Path) -> List[str]:
    if not labels_file.exists():
        raise FileNotFoundError(f"Labels file not found: {labels_file}")
    labels: List[str] = []
    for line in labels_file.read_text(encoding="utf-8").splitlines():
        s = line.strip()
        if not s or s.startswith("#"):
            continue
        labels.append(s)
    if not labels:
        raise ValueError(f"No labels found in {labels_file}")
    return labels


def normalize_tag(s: str) -> str:
    s = s.strip().lower()
    s = s.replace("_", " ")
    s = re.sub(r"[^a-z0-9:+#&' /-]+", "", s)
    s = re.sub(r"\s+", " ", s).strip(" -/")
    return s


def read_taxonomy_map(path: Optional[Path]) -> Dict[str, List[str]]:
    if not path or not path.exists():
        return {}
    mapping: Dict[str, List[str]] = {}
    with path.open("r", encoding="utf-8", newline="") as f:
        sample = f.read(4096)
        f.seek(0)
        has_header = "label" in sample.lower() and ("tag" in sample.lower() or "taxonomy" in sample.lower())
        reader = csv.DictReader(f) if has_header else None
        if reader:
            cols = [c or "" for c in (reader.fieldnames or [])]
            label_col = next((c for c in cols if c.lower() in ("label", "raw_label", "source", "source_label")), cols[0])
            tag_col = next((c for c in cols if c.lower() in ("tags", "tag", "hierarchical_tag", "taxonomy_tag", "mapped_tag")), cols[-1])
            for row in reader:
                label = normalize_tag(row.get(label_col, ""))
                raw_tags = row.get(tag_col, "") or ""
                tags = [normalize_tag(part) for part in re.split(r"[|;]", raw_tags) if normalize_tag(part)]
                if label and tags:
                    mapping[label] = dedupe_preserve_order(tags)
        else:
            f.seek(0)
            for row in csv.reader(f):
                if len(row) >= 2:
                    label = normalize_tag(row[0])
                    tags = [normalize_tag(part) for part in re.split(r"[|;]", row[1]) if normalize_tag(part)]
                    if label and tags:
                        mapping[label] = dedupe_preserve_order(tags)
    return mapping


def ai_tag(tag: str, prefix: bool) -> str:
    tag = normalize_tag(tag)
    if not tag:
        return ""
    return f"{AI_PREFIX}{tag}" if prefix else tag


def map_labels(label: str, taxonomy: Dict[str, List[str]]) -> List[str]:
    label_n = normalize_tag(label)
    return taxonomy.get(label_n, [label_n])


def map_label(label: str, taxonomy: Dict[str, List[str]]) -> str:
    """Compatibility helper for places that need one representative tag."""
    return map_labels(label, taxonomy)[0]


def dedupe_preserve_order(items: Sequence[str]) -> List[str]:
    seen = set()
    out = []
    for item in items:
        if not item:
            continue
        key = item.casefold()
        if key in seen:
            continue
        seen.add(key)
        out.append(item)
    return out


def split_existing_and_ai_tags(tags: Sequence[str]) -> Tuple[List[str], List[str]]:
    human: List[str] = []
    ai: List[str] = []
    for t in tags:
        if t.startswith(AI_PREFIX):
            ai.append(t)
        else:
            human.append(t)
    return human, ai


def merge_tags(existing_tags: Sequence[str], new_raw_tags: Sequence[str], prefix_ai: bool) -> List[str]:
    human_tags, existing_ai_tags = split_existing_and_ai_tags(existing_tags)
    new_ai_tags = [ai_tag(t, prefix_ai) for t in new_raw_tags]
    new_ai_tags = [t for t in new_ai_tags if t]
    # Replace AI tags, preserve human tags. This avoids old weak AI tags lingering forever.
    return dedupe_preserve_order([*human_tags, *new_ai_tags])


def sidecar_path_for_media(media_path: Path) -> Path:
    return media_path.with_suffix(media_path.suffix + ".xmp")


def read_xmp(xmp_path: Path) -> Tuple[List[str], Optional[str], Optional[str], Optional[ET.ElementTree]]:
    if not xmp_path.exists():
        return [], None, None, None
    try:
        tree = ET.parse(xmp_path)
        root = tree.getroot()
        tags: List[str] = []
        for li in root.findall(".//dc:subject/rdf:Bag/rdf:li", NAMESPACES):
            if li.text and li.text.strip():
                tags.append(li.text.strip())
        if not tags:
            for li in root.findall(".//{*}subject//{*}li"):
                if li.text and li.text.strip():
                    tags.append(li.text.strip())
        description: Optional[str] = None
        desc_node = root.find(".//dc:description/rdf:Alt/rdf:li", NAMESPACES)
        if desc_node is not None and desc_node.text:
            description = desc_node.text.strip()
        if description is None:
            desc_node = root.find(".//{*}description//{*}li")
            if desc_node is not None and desc_node.text:
                description = desc_node.text.strip()
        last_tagged = None
        desc = root.find(".//rdf:Description", NAMESPACES)
        if desc is None:
            desc = root.find(".//{*}Description")
        if desc is not None:
            last_tagged = desc.get(f"{{{NAMESPACES['immichai']}}}lastTaggedAt")
        return dedupe_preserve_order(tags), description, last_tagged, tree
    except ET.ParseError:
        eprint(f"Warning: could not parse existing XMP, starting fresh: {xmp_path}")
        return [], None, None, None


def xmp_tag_status(path: Path) -> Tuple[int, bool, Optional[str]]:
    tags, _desc, last_tagged, _tree = read_xmp(sidecar_path_for_media(path))
    ai_tags = [t for t in tags if t.startswith(AI_PREFIX)]
    if not tags:
        return 0, True, last_tagged
    if len(tags) <= 1:
        return len(tags), True, last_tagged
    if ai_tags and all(t in WEAK_TAGS or t.startswith(WEAK_TAG_PREFIXES) for t in ai_tags):
        return len(tags), True, last_tagged
    return len(tags), False, last_tagged


def ensure_rdf_description(root: ET.Element) -> ET.Element:
    rdf = root.find("rdf:RDF", NAMESPACES)
    if rdf is None:
        rdf = root.find(".//{*}RDF")
    if rdf is None:
        rdf = ET.SubElement(root, f"{{{NAMESPACES['rdf']}}}RDF")
    desc = rdf.find("rdf:Description", NAMESPACES)
    if desc is None:
        desc = rdf.find("{http://www.w3.org/1999/02/22-rdf-syntax-ns#}Description")
    if desc is None:
        desc = ET.SubElement(rdf, f"{{{NAMESPACES['rdf']}}}Description")
    return desc


def upsert_subject_description_and_ai_meta(
    tree: Optional[ET.ElementTree],
    tags: Sequence[str],
    description: Optional[str],
    tagger_version: str,
) -> ET.ElementTree:
    if tree is None:
        root = ET.Element(f"{{{NAMESPACES['x']}}}xmpmeta")
        tree = ET.ElementTree(root)
    root = tree.getroot()
    desc = ensure_rdf_description(root)

    for node in list(desc.findall("dc:subject", NAMESPACES)):
        desc.remove(node)
    for node in list(desc.findall("{http://purl.org/dc/elements/1.1/}subject")):
        if node in list(desc):
            desc.remove(node)

    subject = ET.SubElement(desc, f"{{{NAMESPACES['dc']}}}subject")
    bag = ET.SubElement(subject, f"{{{NAMESPACES['rdf']}}}Bag")
    for tag in tags:
        li = ET.SubElement(bag, f"{{{NAMESPACES['rdf']}}}li")
        li.text = tag

    for node in list(desc.findall("dc:description", NAMESPACES)):
        desc.remove(node)
    for node in list(desc.findall("{http://purl.org/dc/elements/1.1/}description")):
        if node in list(desc):
            desc.remove(node)

    if description:
        dc_desc = ET.SubElement(desc, f"{{{NAMESPACES['dc']}}}description")
        alt = ET.SubElement(dc_desc, f"{{{NAMESPACES['rdf']}}}Alt")
        li = ET.SubElement(alt, f"{{{NAMESPACES['rdf']}}}li")
        li.set("{http://www.w3.org/XML/1998/namespace}lang", "x-default")
        li.text = description

    desc.set(f"{{{NAMESPACES['immichai']}}}lastTaggedAt", iso_now())
    desc.set(f"{{{NAMESPACES['immichai']}}}taggerName", "immich-auto-tagger")
    desc.set(f"{{{NAMESPACES['immichai']}}}taggerVersion", tagger_version)
    return tree


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def normalize_image_for_model(img: Image.Image, max_side: int) -> Image.Image:
    img = ImageOps.exif_transpose(img).convert("RGB")
    w, h = img.size
    long_side = max(w, h)
    if long_side <= max_side:
        return img
    scale = max_side / float(long_side)
    new_size = (max(1, int(round(w * scale))), max(1, int(round(h * scale))))
    return img.resize(new_size, Image.Resampling.LANCZOS)


def model_signature(args: argparse.Namespace, labels: Sequence[str], taxonomy: Dict[str, List[str]]) -> str:
    payload = {
        "zero_shot_model": args.zero_shot_model,
        "caption_model": args.caption_model,
        "caption_task": args.caption_task,
        "caption_prompt": args.caption_prompt,
        "caption_max_new_tokens": args.caption_max_new_tokens,
        "labels": list(labels),
        "taxonomy": taxonomy,
        "max_side": args.max_side,
        "threshold": args.threshold,
        "relative_threshold": args.relative_threshold,
        "top_k": args.top_k,
        "fallback_threshold": args.fallback_threshold,
        "fallback_relative_threshold": args.fallback_relative_threshold,
        "fallback_top_k": args.fallback_top_k,
        "include_videos": args.include_videos,
        "video_frames": args.video_frames,
        "tagger_version": args.tagger_version,
    }
    return hashlib.sha256(json.dumps(payload, ensure_ascii=False, sort_keys=True).encode("utf-8")).hexdigest()


def init_db(conn: sqlite3.Connection) -> None:
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS media_cache (
            path TEXT PRIMARY KEY,
            sha256 TEXT NOT NULL DEFAULT '',
            mtime_ns INTEGER NOT NULL,
            size_bytes INTEGER NOT NULL,
            model_sig TEXT NOT NULL DEFAULT '',
            media_type TEXT NOT NULL DEFAULT 'image',
            data_json TEXT NOT NULL DEFAULT '',
            hash_checked_at REAL NOT NULL DEFAULT 0,
            classified_at REAL NOT NULL DEFAULT 0
        )
        """
    )
    # Old v4 scripts used image_cache. Keep it and make a view-ish migration by copying available rows.
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS image_cache (
            path TEXT PRIMARY KEY,
            sha256 TEXT NOT NULL,
            mtime_ns INTEGER NOT NULL,
            size_bytes INTEGER NOT NULL,
            model_sig TEXT NOT NULL DEFAULT '',
            data_json TEXT NOT NULL
        )
        """
    )
    conn.execute("CREATE INDEX IF NOT EXISTS idx_media_cache_model ON media_cache(model_sig)")
    conn.commit()


def get_media_cache(conn: sqlite3.Connection, path: Path) -> Optional[sqlite3.Row]:
    conn.row_factory = sqlite3.Row
    row = conn.execute("SELECT * FROM media_cache WHERE path = ?", (str(path),)).fetchone()
    if row:
        return row
    old = conn.execute("SELECT * FROM image_cache WHERE path = ?", (str(path),)).fetchone()
    return old


def get_cached_result(conn: sqlite3.Connection, path: Path, sha256: str, mtime_ns: int, size_bytes: int, model_sig: str) -> Optional[dict]:
    conn.row_factory = sqlite3.Row
    row = conn.execute(
        "SELECT data_json, sha256, mtime_ns, size_bytes, model_sig FROM media_cache WHERE path = ?",
        (str(path),),
    ).fetchone()
    if not row:
        row = conn.execute(
            "SELECT data_json, sha256, mtime_ns, size_bytes, model_sig FROM image_cache WHERE path = ?",
            (str(path),),
        ).fetchone()
    if not row:
        return None
    if row["sha256"] == sha256 and row["mtime_ns"] == mtime_ns and row["size_bytes"] == size_bytes and row["model_sig"] == model_sig and row["data_json"]:
        try:
            return json.loads(row["data_json"])
        except Exception:
            return None
    return None


def put_hash_cache(conn: sqlite3.Connection, path: Path, sha256: str, mtime_ns: int, size_bytes: int, media_type: str) -> None:
    conn.execute(
        """
        INSERT INTO media_cache(path, sha256, mtime_ns, size_bytes, media_type, hash_checked_at)
        VALUES (?, ?, ?, ?, ?, ?)
        ON CONFLICT(path) DO UPDATE SET
            sha256=excluded.sha256,
            mtime_ns=excluded.mtime_ns,
            size_bytes=excluded.size_bytes,
            media_type=excluded.media_type,
            hash_checked_at=excluded.hash_checked_at
        """,
        (str(path), sha256, mtime_ns, size_bytes, media_type, time.time()),
    )
    conn.commit()


def put_cached_result(conn: sqlite3.Connection, path: Path, sha256: str, mtime_ns: int, size_bytes: int, model_sig: str, media_type: str, data: dict) -> None:
    data_json = json.dumps(data, ensure_ascii=False)
    conn.execute(
        """
        INSERT INTO media_cache(path, sha256, mtime_ns, size_bytes, model_sig, media_type, data_json, hash_checked_at, classified_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(path) DO UPDATE SET
            sha256=excluded.sha256,
            mtime_ns=excluded.mtime_ns,
            size_bytes=excluded.size_bytes,
            model_sig=excluded.model_sig,
            media_type=excluded.media_type,
            data_json=excluded.data_json,
            hash_checked_at=excluded.hash_checked_at,
            classified_at=excluded.classified_at
        """,
        (str(path), sha256, mtime_ns, size_bytes, model_sig, media_type, data_json, time.time(), time.time()),
    )
    # Also update old table for captioner compatibility.
    if media_type == "image":
        conn.execute(
            """
            INSERT INTO image_cache(path, sha256, mtime_ns, size_bytes, model_sig, data_json)
            VALUES (?, ?, ?, ?, ?, ?)
            ON CONFLICT(path) DO UPDATE SET
                sha256=excluded.sha256,
                mtime_ns=excluded.mtime_ns,
                size_bytes=excluded.size_bytes,
                model_sig=excluded.model_sig,
                data_json=excluded.data_json
            """,
            (str(path), sha256, mtime_ns, size_bytes, model_sig, data_json),
        )
    conn.commit()


